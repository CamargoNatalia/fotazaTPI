extends ../layout

block content

  h1 Registro de usuario

  if error
    p (style='color:red')= error

  form(action='/usuarios/nuevo' method='POST')

    div
      label(for='nombre') Nombre:
      input(
        type='text'
        id='nombre'
        name='nombre'
        required
      )

    div
      label(for='dni') DNI:
      input(
        type='text'
        id='dni'
        name='dni'
        required
      )

    div
      label(for='email') Email:
      input(
        type='email'
        id='email'
        name='email'
        required
      )

    div
      label(for='password') Contraseña:
      input(
        type='password'
        id='password'
        name='password'
        required
      )

    button(type='submit') Registrarse