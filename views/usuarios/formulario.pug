extends ../layout

block content
  .registro-container
    .registro-card
      h1 Registro de Usuario
      .registro-subtitulo Creá tu cuenta para compartir momentos

      if error
        .error-message #{error}

      form(action='/usuarios/nuevo' method='POST')
        .form-group
          label(for='nombre') Nombre completo
          input#nombre(
            type='text'
            name='nombre'
            placeholder='Ej: Juan Pérez'
            required
          )

        .form-group
          label(for='dni') DNI
          input#dni(
            type='text'
            name='dni'
            placeholder='Ej: 12345678'
            required
          )

        .form-group
          label(for='email') Correo electrónico
          input#email(
            type='email'
            name='email'
            placeholder='ejemplo@correo.com'
            required
          )

        .form-group
          label(for='password') Contraseña
          input#password(
            type='password'
            name='password'
            placeholder='********'
            required
          )

        button.btn-registro(type='submit') Registrarse

      .registro-footer
        | ¿Ya tenés cuenta? 
        a(href='/login') Iniciar sesión