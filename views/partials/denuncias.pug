div.denuncia.mt-3

    if currentUser

        - const yaDenuncio = publicacion.Denuncia && publicacion.Denuncia.some(d => d.usuarioId === currentUser.id)

        if yaDenuncio

            button.btn.btn-sm.btn-secondary(
                type='button'
                disabled
            )
                | Ya denunciaste esta publicación

        else

            a.btn.btn-sm.btn-danger(
                href=`/denuncias/${publicacion.id}`
            )
                | Denunciar publicación

    else

        p.text-muted
            | Debes iniciar sesión para denunciar.